{
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": ["-y", "@upstash/context7-mcp@latest"]
        },
        "sequential-thinking": {
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
        },
        "qmd": {
            "command": "qmd",
            "args": ["mcp"]
        },
        "fff": {
            "type": "stdio",
            "command": "fff-mcp",
            "args": []
        },
        "searxng": {
            "command": "uvx",
            "args": [
                "mcp-searxng"
            ],
            "env": {
                "SEARXNG_URL": "http://localhost:8080"
            }
        }
    }
}
