{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@superwhisper/opencode",
    "@tarquinen/opencode-dcp@latest",
    "opencode-openai-codex-auth",
    "opencode-claude-bridge"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 4096
  },
  "mcp": {
    "searxng": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-searxng"
      ],
      "enabled": true,
      "environment": {
        "SEARXNG_URL": "http://10.1.20.93:8080"
      }
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "hf.co/HauhauCS/Qwen3.5-9B-Uncensored-HauhauCS-Aggressive:Q4_K_M": {
          "name": "Qwen3.5 9B Uncensored HauhauCS Aggressive (Q4_K_M)",
          "limit": {
            "context": 16384,
            "output": 4096
          }
        }
      }
    }
  }
}
